{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "id": "https://gitlab.seznam.net/iup/vydej/http-servers/-/raw/master/hit-sem-logger/schema/sem-hit-json-schema-v2.json",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "schema_version",
        "event_name",
        "event_time",
        "event_type",
        "event_data"
    ],
    "properties": {
        "sandbox": {
            "description": "Sandbox token indicating whether the event is sent in a test environment (sandbox) or in a production environment. See https://datacollect.glpages.seznam.net/documentation/hits/sandboxtoken/ for more details.",
            "type": "string"
        },
        "api": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "version"],
            "properties": {
                "name": { "type": "string" },
                "version": { "type": "string" },
                "template_version": { "type": "string" }
            }
        },
        "consent_mode": {
            "title": "Google consent mode v2",
            "type": "object",
            "additionalProperties": false,
            "anyOf": [
                { "required": ["ad_storage"] },
                { "required": ["ad_user_data"] },
                { "required": ["ad_personalization"] },
                { "required": ["functionality_storage"] },
                { "required": ["analytics_storage"] }
            ],
            "properties": {
                "ad_storage": { "title": "Permission to store and process user data for advertising purposes.", "type": "string", "enum": ["granted", "denied"] },
                "ad_user_data": { "title": "Permission to use user identifiers generated from direct user data (e.g., hashed email) for advertising purposes.", "type": "string", "enum": ["granted", "denied"] },
                "ad_personalization": { "title": "Permission to store and process user data for personalized advertising.", "type": "string", "enum": ["granted", "denied"] },
                "functionality_storage": { "title": "Permission to store and process user data for basic functionality.", "type": "string", "enum": ["granted", "denied"] },
                "analytics_storage": { "title": "Permission to store and process user data for analytics, performance measurement, and product development.", "type": "string", "enum": ["granted", "denied"] }
            }
        },
        "consent_string": {
            "description": "Transparency and Consent Framework (TCF) standard, created by IAB Europe.",
            "type": "string"
        },
        "s2s_headers": {
            "description": "Original client headers for which the server proxies the event in server to server (s2s) communication",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "client_ip_address": { "type": "string", "anyOf": [{ "format": "ipv4" }, { "format": "ipv6" }] },
                "user_agent": { "type": "string" },
                "sec_ch_ua": { "type": "string" },
                "sec_ch_ua_mobile": { "type": "string" },
                "sec_ch_ua_model": { "type": "string" },
                "sec_ch_ua_platform": { "type": "string" },
                "sec_ch_ua_platform_version": { "type": "string" }
            }
        },
        "schema_version": { "type": "string", "enum": ["v2"] },
        "user_ids": {
            "description": "Identification of the end user.",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "ids": {
                    "type": "object",
                    "additionalProperties": true,
                    "required": ["_version"],
                    "properties": {
                        "sid": { "type": "string", "pattern": "^id=([0-9]+)|t=(0-9)+\\.(0-9){3}|te=(0-9)+\\.(0-9){3}|c=.*$" },
                        "udid": { "type": "string" },
                        "secid": { "type": "string" },
                        "id5": { "type": "string" },
                        "_version": { "type": "string" }
                    }
                },
                "user_data": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "em": { "title": "Email hash", "type": "string" },
                        "ph": { "title": "Phone hash", "type": "string" },
                        "fn": { "title": "First Name hash", "type": "string" },
                        "ln": { "title": "Last Name hash", "type": "string" },
                        "ge": { "title": "Gender hash", "type": "string" },
                        "db": { "description": "Date of birth hashed", "type": "string" },
                        "ct": { "title": "City hashed", "type": "string" },
                        "st": { "title": "State hashed", "type": "string" },
                        "zp": { "title": "ZIP Code without spaces hashed", "type": "string" },
                        "sr": { "title": "Street and house number hashed", "type": "string" },
                        "country": { "description": "Two-letter ISO country code, e.g., cz, sk, us. Hashed.", "type": "string" },
                        "said": { "title": "Encrypted 'rusid' value for advertisement.", "type": "string" },
                        "id5": { "title": "ID5 identifier", "type": "string" },
                        "secid": { "title": "Czech Ad ID identity (secondary ID)", "type": "string" },
                        "udid": { "title": "Unique user identifier within the domain", "type": "string" },
                        "sid": { "title": "SID cookie", "type": "string", "pattern": "^id=([0-9]+)|t=(0-9)+\\.(0-9){3}|te=(0-9)+\\.(0-9){3}|c=.*$" },
                        "subscription_id": { "type": "string" }
                    }
                }
            }
        },
        "event_source": {
            "description": "Source of the webhit such as specific web service or mobile application.",
            "type": "string"
        },
        "event_name": { "title": "Name of the selected event.", "type": "string" },
        "event_type": {
            "title": "Event type",
            "type": "string",
            "enum": ["web", "app", "rtgconv", "geo", "poi"]
        },
        "event_time": {
            "title": "Unix time in milliseconds",
            "type": "integer",
            "exclusiveMinimum": 0
        },
        "event_id": {
            "title": "Unique ID of the event sent by the client. If missing logger generates its own UUID v7.",
            "type": "string"
        },
        "event_url": {
            "description": "Current URL of the page where the hit originated",
            "type": "string"
        },
        "event_data": {
            "description": "Data specific to certain event_type",
            "type": "object",
            "additionalProperties": true
        }
    }
}
